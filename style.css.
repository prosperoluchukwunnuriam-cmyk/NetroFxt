/* ============================================================
   NetroFx— Main Stylesheet
   Color Palette: Navy + Electric Blue
   ============================================================ */

/* ---- CSS Variables ---- */
:root {
  --navy-950: #020817;
  --navy-900: #0A1628;
  --navy-800: #0F2346;
  --navy-700: #1E3A8A;
  --navy-600: #1D4ED8;
  --blue-500: #3B82F6;
  --blue-400: #60A5FA;
  --blue-300: #93C5FD;
  --cyan-400: #22D3EE;
  --cyan-300: #67E8F9;
  --indigo-500: #6366F1;
  --gold-400: #F59E0B;
  --gold-300: #FCD34D;
  --white: #FFFFFF;
  --text-primary: #F1F5F9;
  --text-secondary: #94A3B8;
  --text-muted: #64748B;
  --border: rgba(59, 130, 246, 0.15);
  --border-bright: rgba(59, 130, 246, 0.35);
  --card-bg: rgba(15, 35, 70, 0.6);
  --card-hover: rgba(30, 58, 138, 0.5);
  --glass: rgba(255, 255, 255, 0.04);
  --shadow: 0 4px 24px rgba(2, 8, 23, 0.6);
  --shadow-blue: 0 0 40px rgba(59, 130, 246, 0.25);
  --radius: 16px;
  --radius-sm: 10px;
  --radius-lg: 24px;
  --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ---- Reset & Base ---- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; font-size: 16px; }

body {
  background-color: var(--navy-950);
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  font-weight: 400;
  line-height: 1.6;
  overflow-x: hidden;
}

a { color: inherit; text-decoration: none; }
ul { list-style: none; }
img { max-width: 100%; display: block; }

/* ---- Container ---- */
.container {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ---- Typography ---- */
h1, h2, h3, h4 {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.02em;
}

.gradient-text {
  background: linear-gradient(135deg, var(--blue-400) 0%, var(--cyan-400) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ---- Buttons ---- */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: 10px;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: var(--transition);
  border: none;
  white-space: nowrap;
  text-decoration: none;
  font-family: 'Inter', sans-serif;
}

.btn-primary {
  background: linear-gradient(135deg, var(--navy-600) 0%, var(--blue-500) 100%);
  color: white;
  box-shadow: 0 4px 20px rgba(59, 130, 246, 0.35);
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(59, 130, 246, 0.5);
}

.btn-ghost {
  background: transparent;
  color: var(--text-primary);
  border: 1px solid var(--border);
}
.btn-ghost:hover {
  border-color: var(--blue-400);
  color: var(--blue-400);
}

.btn-outline {
  background: transparent;
  color: var(--blue-400);
  border: 1.5px solid var(--blue-500);
}
.btn-outline:hover {
  background: rgba(59, 130, 246, 0.1);
  transform: translateY(-2px);
}

.btn-gold {
  background: linear-gradient(135deg, #92400E, var(--gold-400));
  color: white;
  box-shadow: 0 4px 20px rgba(245, 158, 11, 0.3);
}
.btn-gold:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(245, 158, 11, 0.45);
}

.btn-lg {
  padding: 15px 32px;
  font-size: 1rem;
  border-radius: 12px;
}

.btn-full { width: 100%; justify-content: center; }

/* ---- Section Common ---- */
.section-label {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--blue-400);
  background: rgba(59, 130, 246, 0.1);
  border: 1px solid rgba(59, 130, 246, 0.25);
  padding: 5px 14px;
  border-radius: 20px;
  margin-bottom: 16px;
}

.section-title {
  font-size: clamp(1.9rem, 4vw, 2.8rem);
  color: var(--white);
  margin-bottom: 16px;
}

.section-desc {
  font-size: 1.05rem;
  color: var(--text-secondary);
  max-width: 580px;
  margin: 0 auto 56px;
  text-align: center;
}

/* ---- AOS (Animate on Scroll) ---- */
[data-aos] {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
[data-aos].aos-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================================
   NAVBAR
============================================================ */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  padding: 18px 0;
  transition: background var(--transition), padding var(--transition), box-shadow var(--transition);
}
.navbar.scrolled {
  background: rgba(2, 8, 23, 0.9);
  backdrop-filter: blur(20px);
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
  box-shadow: 0 4px 24px rgba(2, 8, 23, 0.5);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
}
.logo-icon { flex-shrink: 0; }
.logo-text {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--white);
  letter-spacing: -0.03em;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 6px;
}
.nav-links a {
  padding: 8px 14px;
  font-size: 0.92rem;
  font-weight: 500;
  color: var(--text-secondary);
  border-radius: 8px;
  transition: var(--transition);
}
.nav-links a:hover,
.nav-links a.active {
  color: var(--white);
  background: rgba(255,255,255,0.06);
}
.nav-links a.active {
  color: var(--blue-400);
}

.nav-cta {
  display: flex;
  align-items: center;
  gap: 10px;
}

.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.hamburger span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: var(--transition);
}

/* Mobile menu */
.mobile-menu {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0;
  background: rgba(2, 8, 23, 0.97);
  backdrop-filter: blur(20px);
  padding: 80px 24px 40px;
  z-index: 999;
  border-bottom: 1px solid var(--border);
  transform: translateY(-100%);
  transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
}
.mobile-menu.open { transform: translateY(0); }
.mobile-menu ul { display: flex; flex-direction: column; gap: 4px; margin-bottom: 24px; }
.mobile-menu ul a {
  display: block;
  padding: 14px 16px;
  font-size: 1.1rem;
  font-weight: 500;
  border-radius: 10px;
  transition: background var(--transition);
}
.mobile-menu ul a:hover { background: rgba(59,130,246,0.1); color: var(--blue-400); }
.mobile-cta { display: flex; flex-direction: column; gap: 10px; }

/* ============================================================
   HERO
============================================================ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-top: 80px;
}

.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
}
.hero-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
}
.glow-1 {
  width: 700px; height: 700px;
  top: -200px; left: -200px;
  background: radial-gradient(circle, rgba(30,58,138,0.6) 0%, transparent 70%);
}
.glow-2 {
  width: 600px; height: 600px;
  bottom: 0; right: -150px;
  background: radial-gradient(circle, rgba(59,130,246,0.3) 0%, transparent 70%);
}
.grid-overlay {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(59,130,246,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(59,130,246,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
}

.hero-inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 60px;
  padding: 80px 24px 60px;
  flex: 1;
}

/* Hero Content */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(59,130,246,0.1);
  border: 1px solid rgba(59,130,246,0.3);
  border-radius: 30px;
  padding: 7px 16px;
  font-size: 0.83rem;
  color: var(--blue-300);
  margin-bottom: 24px;
  width: fit-content;
}
.badge-dot {
  width: 8px; height: 8px;
  background: var(--cyan-400);
  border-radius: 50%;
  animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.7); }
}

.hero-title {
  font-size: clamp(2.4rem, 5vw, 3.8rem);
  color: var(--white);
  margin-bottom: 24px;
  line-height: 1.1;
}

.hero-desc {
  font-size: 1.1rem;
  color: var(--text-secondary);
  margin-bottom: 36px;
  max-width: 520px;
  line-height: 1.7;
}

.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 56px;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 0;
}
.stat-item {
  display: flex;
  flex-direction: column;
  padding: 0 28px;
}
.stat-item:first-child { padding-left: 0; }
.stat-num {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1;
}
.stat-unit {
  font-size: 1.3rem;
  color: var(--blue-400);
  font-weight: 700;
}
.stat-label {
  font-size: 0.78rem;
  color: var(--text-muted);
  margin-top: 4px;
}
.stat-divider {
  width: 1px;
  height: 40px;
  background: var(--border-bright);
}

/* ---- Phone Mockup ---- */
.hero-visual {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.phone-mockup {
  position: relative;
  width: 300px;
}

.phone-frame {
  background: linear-gradient(160deg, var(--navy-800) 0%, var(--navy-950) 100%);
  border: 1.5px solid rgba(59,130,246,0.3);
  border-radius: 36px;
  padding: 16px;
  box-shadow: var(--shadow-blue), 0 32px 80px rgba(2,8,23,0.8);
  position: relative;
  z-index: 2;
}
.phone-frame::before {
  content: '';
  position: absolute;
  top: 12px; left: 50%; transform: translateX(-50%);
  width: 60px; height: 4px;
  background: rgba(255,255,255,0.1);
  border-radius: 2px;
}

.phone-screen {
  background: var(--navy-900);
  border-radius: 24px;
  padding: 20px 16px;
  overflow: hidden;
}

.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-secondary);
}
.app-logo-sm {
  background: linear-gradient(135deg, var(--navy-600), var(--blue-500));
  color: white;
  width: 28px; height: 28px;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem; font-weight: 800;
}

.portfolio-balance {
  display: flex;
  flex-direction: column;
  gap: 3px;
  margin-bottom: 16px;
}
.balance-label { font-size: 0.72rem; color: var(--text-muted); }
.balance-amount {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--white);
}
.balance-change { font-size: 0.72rem; }
.balance-change.positive { color: #10B981; }
.balance-change.negative { color: #F87171; }

.mini-chart {
  width: 100%;
  height: 60px;
  margin-bottom: 14px;
  border-radius: 8px;
  overflow: hidden;
}
.mini-chart svg { width: 100%; height: 100%; }

.coin-list { display: flex; flex-direction: column; gap: 10px; }
.coin-row {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(255,255,255,0.03);
  border-radius: 10px;
  padding: 8px 10px;
}
.coin-icon {
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; font-weight: 700;
  flex-shrink: 0;
}
.coin-icon.btc { background: #F7931A22; color: #F7931A; }
.coin-icon.eth { background: #627EEA22; color: #627EEA; }
.coin-icon.sol { background: #9945FF22; color: #9945FF; }
.coin-info { flex: 1; display: flex; flex-direction: column; }
.coin-info span { font-size: 0.8rem; font-weight: 600; color: var(--white); }
.coin-info small { font-size: 0.68rem; color: var(--text-muted); }
.coin-price { font-size: 0.8rem; font-weight: 600; }
.coin-price.positive { color: #10B981; }
.coin-price.negative { color: #F87171; }

/* Floating cards */
.float-card {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(15,35,70,0.85);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-bright);
  border-radius: 14px;
  padding: 10px 16px;
  box-shadow: 0 8px 32px rgba(2,8,23,0.6);
  z-index: 3;
  animation: float 3s ease-in-out infinite;
}
.float-card i { color: var(--blue-400); font-size: 1.1rem; }
.float-card div { display: flex; flex-direction: column; }
.float-card span { font-size: 0.78rem; font-weight: 600; color: var(--white); }
.float-card small { font-size: 0.65rem; color: var(--text-muted); }

.card-1 { top: 20px; left: -70px; animation-delay: 0s; }
.card-2 { bottom: 60px; left: -60px; animation-delay: 1s; }
.card-3 {
  top: 30%;
  right: -60px;
  animation-delay: 0.5s;
  flex-direction: column;
  gap: 4px;
  align-items: flex-start;
}
.spark-bar {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 20px;
}
.spark-bar::before {
  content: '';
  display: block;
  background: linear-gradient(to top, var(--blue-500), var(--cyan-400));
  width: 3px; border-radius: 2px;
  height: 8px;
}
.spark-label { font-size: 0.68rem; color: var(--blue-300); font-weight: 600; }

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

/* ---- Ticker ---- */
.ticker-wrap {
  position: relative;
  z-index: 1;
  background: var(--navy-900);
  border-top: 1px solid var(--border);
  padding: 12px 0;
  overflow: hidden;
}
.ticker {
  display: flex;
  gap: 0;
  width: max-content;
  animation: ticker-scroll 40s linear infinite;
}
.ticker:hover { animation-play-state: paused; }
.ticker-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 24px;
  border-right: 1px solid var(--border);
  white-space: nowrap;
}
.t-name { font-size: 0.82rem; font-weight: 700; color: var(--text-secondary); }
.t-price { font-size: 0.82rem; font-weight: 600; color: var(--white); }
.t-change { font-size: 0.78rem; font-weight: 600; }
.t-change.pos { color: #10B981; }
.t-change.neg { color: #F87171; }

@keyframes ticker-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ============================================================
   MEDIA LOGOS
============================================================ */
.media-logos {
  padding: 56px 0;
  border-bottom: 1px solid var(--border);
}
.media-label {
  text-align: center;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  margin-bottom: 24px;
}
.logos-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48px;
  flex-wrap: wrap;
}
.logo-item {
  color: var(--text-muted);
  opacity: 0.6;
  transition: var(--transition);
  display: flex;
  align-items: center;
}
.logo-item:hover { opacity: 1; color: var(--blue-300); }

/* ============================================================
   FEATURES
============================================================ */
.features {
  padding: 100px 0;
  text-align: center;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.feature-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px 28px;
  text-align: left;
  transition: var(--transition);
  backdrop-filter: blur(10px);
}
.feature-card:hover {
  border-color: var(--border-bright);
  background: var(--card-hover);
  transform: translateY(-4px);
  box-shadow: var(--shadow-blue);
}

.feature-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  margin-bottom: 20px;
}
.feature-icon.blue { background: rgba(59,130,246,0.15); color: var(--blue-400); }
.feature-icon.cyan { background: rgba(34,211,238,0.12); color: var(--cyan-400); }
.feature-icon.indigo { background: rgba(99,102,241,0.12); color: var(--indigo-500); }

.feature-card h3 {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 10px;
}
.feature-card p {
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.65;
}

/* ============================================================
   INVEST SECTION
============================================================ */
.invest {
  padding: 100px 0;
  background: linear-gradient(180deg, var(--navy-950) 0%, var(--navy-900) 50%, var(--navy-950) 100%);
}

.invest-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.invest-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: var(--transition);
  backdrop-filter: blur(10px);
}
.invest-card:hover { border-color: var(--border-bright); }

.invest-visual {
  padding: 32px 32px 0;
  min-height: 220px;
  display: flex;
  align-items: flex-end;
}

/* Chart in Grow card */
.invest-chart-wrap {
  width: 100%;
  position: relative;
}
.invest-chart-svg {
  width: 100%;
  height: 180px;
  display: block;
}
.chart-label-top {
  position: absolute;
  top: 0; right: 0;
  background: rgba(96,165,250,0.12);
  border: 1px solid rgba(96,165,250,0.25);
  border-radius: 10px;
  padding: 8px 14px;
  display: flex;
  flex-direction: column;
}
.chart-label-top span { font-size: 0.72rem; color: var(--blue-300); }
.chart-label-top strong { font-size: 1rem; font-weight: 700; color: var(--white); }

/* Private card visual */
.private-visual {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
  padding-bottom: 20px;
  position: relative;
}
.vault-icon {
  position: relative;
  z-index: 3;
  width: 72px; height: 72px;
  border-radius: 50%;
  background: linear-gradient(135deg, #92400E, var(--gold-400));
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem;
  color: white;
  box-shadow: 0 0 40px rgba(245,158,11,0.35);
}
.private-rings {
  position: absolute;
  top: 30px; left: 50%; transform: translateX(-50%);
  width: 72px; height: 72px;
}
.ring {
  position: absolute;
  top: 50%; left: 50%; transform: translate(-50%,-50%);
  border-radius: 50%;
  border: 1px solid rgba(245,158,11,0.25);
  animation: ring-pulse 3s ease-in-out infinite;
}
.ring-1 { width: 100px; height: 100px; animation-delay: 0s; }
.ring-2 { width: 140px; height: 140px; animation-delay: 0.5s; }
.ring-3 { width: 180px; height: 180px; animation-delay: 1s; }
@keyframes ring-pulse {
  0%, 100% { opacity: 0.3; transform: translate(-50%,-50%) scale(1); }
  50% { opacity: 0.7; transform: translate(-50%,-50%) scale(1.05); }
}

.private-stats-wrap {
  display: flex;
  gap: 24px;
  position: relative;
  z-index: 3;
  margin-top: 60px;
}
.pvt-stat {
  text-align: center;
  background: rgba(245,158,11,0.08);
  border: 1px solid rgba(245,158,11,0.2);
  border-radius: 12px;
  padding: 12px 20px;
}
.pvt-num { display: block; font-size: 1.1rem; font-weight: 700; color: var(--gold-300); }
.pvt-lbl { display: block; font-size: 0.7rem; color: var(--text-muted); margin-top: 2px; }

/* Invest card content area */
.invest-content {
  padding: 28px 32px 32px;
}

.invest-badge {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--blue-400);
  background: rgba(59,130,246,0.1);
  border: 1px solid rgba(59,130,246,0.2);
  padding: 4px 12px;
  border-radius: 20px;
  margin-bottom: 12px;
}
.invest-badge.gold {
  color: var(--gold-300);
  background: rgba(245,158,11,0.1);
  border-color: rgba(245,158,11,0.2);
}

.invest-content h3 {
  font-size: 1.3rem;
  color: var(--white);
  margin-bottom: 12px;
}
.invest-content p {
  font-size: 0.92rem;
  color: var(--text-secondary);
  margin-bottom: 20px;
  line-height: 1.65;
}
.invest-content strong { color: var(--white); }

.invest-features {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 24px;
}
.invest-features li {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.88rem;
  color: var(--text-secondary);
}
.invest-features li i { color: var(--blue-400); font-size: 0.85rem; flex-shrink: 0; }

/* ============================================================
   SECURITY SECTION
============================================================ */
.security {
  padding: 100px 0;
  position: relative;
  overflow: hidden;
}
.security-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}
.sec-glow {
  position: absolute;
  width: 600px; height: 600px;
  top: 50%; left: 50%; transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(30,58,138,0.4) 0%, transparent 70%);
  border-radius: 50%;
  filter: blur(60px);
}

.security-inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 80px;
}

/* Security visual */
.sec-graphic {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sec-hex-grid {
  display: grid;
  grid-template-columns: repeat(4, 64px);
  gap: 10px;
  justify-content: center;
}

.hex-cell {
  width: 64px; height: 64px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  background: var(--card-bg);
  border: 1px solid var(--border);
  color: var(--text-muted);
  transition: var(--transition);
}
.hex-cell.active {
  background: rgba(59,130,246,0.15);
  border-color: rgba(59,130,246,0.4);
  color: var(--blue-400);
  box-shadow: 0 0 20px rgba(59,130,246,0.2);
  animation: hex-glow 2s ease-in-out infinite alternate;
}
@keyframes hex-glow {
  from { box-shadow: 0 0 12px rgba(59,130,246,0.2); }
  to { box-shadow: 0 0 30px rgba(59,130,246,0.45); }
}

.sec-center-badge {
  position: absolute;
  background: linear-gradient(135deg, var(--navy-700), var(--blue-500));
  border-radius: 50%;
  width: 80px; height: 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 50px rgba(59,130,246,0.5);
  border: 2px solid rgba(96,165,250,0.5);
  pointer-events: none;
}
.sec-center-badge i { font-size: 1.3rem; color: white; }
.sec-center-badge span { font-size: 0.7rem; font-weight: 700; color: white; }
.sec-center-badge small { font-size: 0.55rem; color: var(--blue-300); }

/* Security items */
.security-items { display: flex; flex-direction: column; gap: 28px; margin-top: 32px; }
.sec-item {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.sec-item-icon {
  width: 46px; height: 46px;
  border-radius: 12px;
  background: rgba(59,130,246,0.1);
  border: 1px solid rgba(59,130,246,0.2);
  color: var(--blue-400);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.sec-item h4 { font-size: 0.98rem; color: var(--white); margin-bottom: 4px; }
.sec-item p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; }

/* ============================================================
   HOW IT WORKS
============================================================ */
.how-it-works {
  padding: 100px 0;
  text-align: center;
  background: var(--navy-900);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.steps-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 0;
}

.step-card {
  flex: 1;
  max-width: 280px;
  padding: 32px 24px;
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-align: center;
  transition: var(--transition);
}
.step-card:hover {
  border-color: var(--border-bright);
  background: var(--card-hover);
  transform: translateY(-4px);
}

.step-num {
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.15em;
  color: var(--blue-400);
  background: rgba(59,130,246,0.1);
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  margin-bottom: 16px;
}

.step-icon {
  width: 56px; height: 56px;
  border-radius: 16px;
  background: linear-gradient(135deg, var(--navy-700), var(--blue-500));
  display: flex; align-items: center; justify-content: center;
  font-size: 1.3rem;
  color: white;
  margin: 0 auto 16px;
  box-shadow: 0 4px 20px rgba(59,130,246,0.3);
}
.step-card h3 { font-size: 1.05rem; color: var(--white); margin-bottom: 8px; }
.step-card p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; }

.step-connector {
  display: flex;
  align-items: center;
  padding: 0 12px;
  margin-top: 68px;
}

/* ============================================================
   TESTIMONIALS
============================================================ */
.testimonials {
  padding: 100px 0;
  text-align: center;
}

.testi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.testi-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px;
  text-align: left;
  transition: var(--transition);
  backdrop-filter: blur(10px);
}
.testi-card:hover {
  border-color: var(--border-bright);
  transform: translateY(-3px);
  box-shadow: var(--shadow-blue);
}

.testi-card.featured {
  border-color: rgba(59,130,246,0.4);
  background: rgba(30,58,138,0.25);
}

.testi-stars { display: flex; gap: 4px; color: var(--gold-400); font-size: 0.85rem; margin-bottom: 14px; }
.testi-card p {
  font-size: 0.92rem;
  color: var(--text-secondary);
  line-height: 1.75;
  margin-bottom: 20px;
  font-style: italic;
}
.testi-card p::before { content: '"'; color: var(--blue-400); font-size: 1.3rem; font-style: normal; }

.testi-author { display: flex; align-items: center; gap: 12px; }
.author-avatar {
  width: 42px; height: 42px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.75rem; font-weight: 700;
  flex-shrink: 0;
}
.av1 { background: linear-gradient(135deg, #1D4ED8, #3B82F6); color: white; }
.av2 { background: linear-gradient(135deg, #7C3AED, #A78BFA); color: white; }
.av3 { background: linear-gradient(135deg, #065F46, #10B981); color: white; }
.av4 { background: linear-gradient(135deg, #B45309, #F59E0B); color: white; }

.testi-author strong { font-size: 0.9rem; color: var(--white); display: block; }
.testi-author span { font-size: 0.75rem; color: var(--text-muted); }

/* ============================================================
   PRICING
============================================================ */
.pricing {
  padding: 100px 0;
  background: var(--navy-900);
  border-top: 1px solid var(--border);
  text-align: center;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  align-items: start;
}

.price-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px 28px;
  text-align: left;
  position: relative;
  transition: var(--transition);
  backdrop-filter: blur(10px);
}
.price-card:hover { border-color: var(--border-bright); transform: translateY(-4px); }

.price-card.popular {
  border-color: var(--blue-500);
  background: rgba(30,58,138,0.3);
  box-shadow: var(--shadow-blue), 0 0 0 1px rgba(59,130,246,0.3);
  transform: scale(1.02);
}
.price-card.popular:hover { transform: scale(1.02) translateY(-4px); }

.popular-badge {
  position: absolute;
  top: -14px; left: 50%; transform: translateX(-50%);
  background: linear-gradient(90deg, var(--navy-700), var(--blue-500));
  color: white;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 5px 18px;
  border-radius: 20px;
  white-space: nowrap;
}

.price-tier {
  font-size: 0.82rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--blue-300);
  margin-bottom: 10px;
}
.price-amount {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 2.8rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 12px;
  line-height: 1;
}
.currency { font-size: 1.6rem; vertical-align: top; padding-top: 6px; }
.period { font-size: 1rem; color: var(--text-muted); }
.price-desc {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 24px;
  line-height: 1.55;
  text-align: left;
  max-width: 100%;
}

.price-features {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 28px;
}
.price-features li {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.86rem;
  color: var(--text-secondary);
}
.price-features li i { font-size: 0.78rem; color: var(--blue-400); width: 14px; flex-shrink: 0; }
.price-features li.faded { opacity: 0.35; }
.price-features li.faded i { color: var(--text-muted); }

/* ============================================================
   CTA SECTION
============================================================ */
.cta-section {
  padding: 120px 0;
  position: relative;
  overflow: hidden;
}
.cta-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--navy-900) 0%, var(--navy-800) 100%);
  z-index: 0;
}
.cta-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(30,58,138,0.5) 0%, transparent 70%);
  border-top: 1px solid rgba(59,130,246,0.2);
  border-bottom: 1px solid rgba(59,130,246,0.2);
}
.cta-inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 80px;
}

.cta-title {
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--white);
  margin-bottom: 16px;
}
.cta-content > p {
  font-size: 1rem;
  color: var(--text-secondary);
  margin-bottom: 32px;
  line-height: 1.7;
}

.email-form {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
}
.email-input {
  flex: 1;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border-bright);
  border-radius: 10px;
  padding: 14px 18px;
  font-size: 0.95rem;
  color: var(--white);
  font-family: 'Inter', sans-serif;
  transition: var(--transition);
  outline: none;
}
.email-input::placeholder { color: var(--text-muted); }
.email-input:focus {
  border-color: var(--blue-400);
  background: rgba(59,130,246,0.08);
}
.cta-small { font-size: 0.78rem; color: var(--text-muted); display: block; }

/* CTA Phone mockup */
.cta-phone {
  display: flex;
  justify-content: center;
}
.cta-phone-inner {
  background: linear-gradient(160deg, var(--navy-800), var(--navy-950));
  border: 1.5px solid rgba(59,130,246,0.3);
  border-radius: 28px;
  padding: 24px;
  width: 280px;
  box-shadow: var(--shadow-blue);
}
.cta-app-screen {
  background: var(--navy-900);
  border-radius: 18px;
  padding: 24px;
}
.cta-welcome {
  text-align: center;
  margin-bottom: 20px;
}
.cta-welcome span { font-size: 0.78rem; color: var(--text-muted); display: block; margin-bottom: 2px; }
.cta-welcome strong { font-size: 1.2rem; font-family: 'Space Grotesk', sans-serif; color: var(--white); }

.cta-form-mock { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
.form-field-mock {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
}
.field-label { font-size: 0.65rem; color: var(--text-muted); margin-bottom: 2px; }
.field-value { font-size: 0.8rem; color: var(--text-secondary); }
.field-value.typing { color: var(--blue-300); }

.cta-btn-mock {
  background: linear-gradient(135deg, var(--navy-700), var(--blue-500));
  border-radius: 8px;
  padding: 12px;
  text-align: center;
  font-size: 0.8rem;
  font-weight: 600;
  color: white;
  margin-top: 4px;
}

.cta-trust-badges {
  display: flex;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
}
.cta-trust-badges span {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 0.68rem;
  color: var(--text-muted);
}
.cta-trust-badges i { color: var(--blue-400); font-size: 0.75rem; }

/* ============================================================
   FOOTER
============================================================ */
.footer {
  background: var(--navy-950);
  border-top: 1px solid var(--border);
  padding: 80px 0 32px;
}

.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 64px;
}

.footer-brand .logo { margin-bottom: 16px; }
.footer-brand p {
  font-size: 0.88rem;
  color: var(--text-muted);
  line-height: 1.65;
  margin-bottom: 20px;
}

.social-links {
  display: flex;
  gap: 10px;
}
.social-links a {
  width: 36px; height: 36px;
  border-radius: 8px;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  color: var(--text-muted);
  font-size: 0.9rem;
  transition: var(--transition);
}
.social-links a:hover {
  background: rgba(59,130,246,0.15);
  border-color: var(--border-bright);
  color: var(--blue-400);
}

.footer-links-group h4 {
  font-size: 0.82rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--white);
  margin-bottom: 16px;
}
.footer-links-group ul { display: flex; flex-direction: column; gap: 8px; }
.footer-links-group a {
  font-size: 0.86rem;
  color: var(--text-muted);
  transition: var(--transition);
}
.footer-links-group a:hover { color: var(--blue-300); }

.footer-bottom {
  border-top: 1px solid var(--border);
  padding-top: 28px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.footer-bottom p { font-size: 0.8rem; color: var(--text-muted); }
.footer-disclaimer {
  font-size: 0.73rem !important;
  color: rgba(100,116,139,0.6) !important;
  line-height: 1.5;
  max-width: 800px;
}

/* ============================================================
   BACK TO TOP
============================================================ */
.back-to-top {
  position: fixed;
  bottom: 32px; right: 32px;
  width: 44px; height: 44px;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--navy-700), var(--blue-500));
  color: white;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.9rem;
  opacity: 0;
  pointer-events: none;
  transform: translateY(12px);
  transition: var(--transition);
  box-shadow: 0 4px 20px rgba(59,130,246,0.35);
  z-index: 999;
}
.back-to-top.visible {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.back-to-top:hover { transform: translateY(-3px); }

/* ============================================================
   RESPONSIVE
============================================================ */
@media (max-width: 1024px) {
  .hero-inner { grid-template-columns: 1fr; gap: 60px; text-align: center; padding: 60px 24px 40px; }
  .hero-content { display: flex; flex-direction: column; align-items: center; }
  .hero-desc, .hero-badge { max-width: 100%; }
  .hero-stats { justify-content: center; }
  .features-grid { grid-template-columns: repeat(2, 1fr); }
  .invest-grid { grid-template-columns: 1fr; }
  .security-inner { grid-template-columns: 1fr; gap: 48px; }
  .security-visual { order: -1; }
  .testi-grid { grid-template-columns: 1fr; }
  .pricing-grid { grid-template-columns: 1fr; }
  .price-card.popular { transform: scale(1); }
  .price-card.popular:hover { transform: translateY(-4px); }
  .cta-inner { grid-template-columns: 1fr; gap: 48px; }
  .cta-visual { display: none; }
  .footer-top { grid-template-columns: 1fr 1fr; }
  .footer-brand { grid-column: 1 / -1; }
}

@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .hamburger { display: flex; }
  .mobile-menu { display: block; }

  .hero-inner { padding-top: 40px; }
  .hero-title { font-size: 2.1rem; }
  .hero-actions { flex-direction: column; align-items: center; }
  .hero-stats { gap: 0; flex-wrap: wrap; justify-content: center; }
  .stat-item { padding: 8px 16px; }

  .phone-mockup { width: 240px; }
  .float-card { display: none; }

  .features-grid { grid-template-columns: 1fr; }
  .steps-row { flex-direction: column; align-items: center; gap: 16px; }
  .step-connector { display: none; }
  .step-card { max-width: 100%; width: 100%; }

  .sec-hex-grid { grid-template-columns: repeat(3, 56px); }

  .email-form { flex-direction: column; }
  .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
}

@media (max-width: 480px) {
  .section-title { font-size: 1.7rem; }
  .hero-stats { flex-direction: column; gap: 16px; }
  .stat-divider { display: none; }
  .footer-top { grid-template-columns: 1fr; }
  .logos-row { gap: 24px; }
  .logo-item { transform: scale(0.85); }
}
